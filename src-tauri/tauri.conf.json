{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "unichat",
  "version": "0.1.7",
  "identifier": "com.tcs.unichat",
  "build": {
    "beforeDevCommand": "bun run start",
    "devUrl": "http://localhost:1422",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist/unichat/browser"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "unichat",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../dist/unichat/browser": ""
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "unichat"
        ]
      }
    }
  }
}
