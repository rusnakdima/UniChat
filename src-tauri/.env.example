# UniChat OAuth Configuration
# Copy this file to .env and fill in your credentials
# IMPORTANT: Never commit .env to version control!

# =============================================================================
# COMMON SETTINGS
# =============================================================================

# OAuth callback redirect URI (must match your registered OAuth app settings)
UNICHAT_OAUTH_REDIRECT_URI=http://localhost:3456/callback

# =============================================================================
# TWITCH CONFIGURATION
# =============================================================================
# Get credentials from: https://dev.twitch.tv/console/apps
# Required scopes: chat:read, chat:edit, moderator:manage:banned_users

TWITCH_CLIENT_ID=your_twitch_client_id_here
TWITCH_CLIENT_SECRET=your_twitch_client_secret_here

# =============================================================================
# KICK CONFIGURATION
# =============================================================================
# Get credentials from: https://kick.com/settings/applications
# Required scopes: chat:read, chat:write

KICK_CLIENT_ID=your_kick_client_id_here
KICK_CLIENT_SECRET=your_kick_client_secret_here

# Optional: Override Kick OAuth endpoints (usually not needed)
# KICK_AUTHORIZE_URL=https://id.kick.com/oauth/authorize
# KICK_TOKEN_URL=https://id.kick.com/oauth/token
# KICK_USERINFO_URL=https://api.kick.com/public/v1/users
# KICK_REVOKE_URL=https://id.kick.com/oauth/revoke
# KICK_SCOPES=chat:read chat:write

# =============================================================================
# YOUTUBE CONFIGURATION
# =============================================================================
# Get credentials from: https://console.cloud.google.com/apis/credentials
# Required scopes: youtube.readonly, youtube.force-ssl
# Note: You may also need a YouTube Data API Key for some features

YOUTUBE_CLIENT_ID=your_youtube_client_id_here
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret_here

# Optional: YouTube Data API Key (for fetching video IDs without OAuth)
# Get from: https://console.cloud.google.com/apis/credentials
# YOUTUBE_DATA_API_KEY=your_youtube_api_key_here

# =============================================================================
# SETUP INSTRUCTIONS
# =============================================================================
#
# 1. Copy this file:
#    cp .env.example .env
#
# 2. Fill in your credentials for the platforms you want to use
#
# 3. Restart the application after changing credentials
#
# 4. For production builds, set these as environment variables instead
#
# =============================================================================
# PLATFORM-SPECIFIC NOTES
# =============================================================================
#
# TWITCH:
# - Create app at https://dev.twitch.tv/console/apps
# - Set OAuth Redirect URL to: http://localhost:3456/callback
# - Copy Client ID and Client Secret to .env
#
# KICK:
# - Create app at https://kick.com/settings/applications
# - Set Redirect URI to: http://localhost:3456/callback
# - Copy Client ID and Client Secret to .env
#
# YOUTUBE:
# - Create credentials at https://console.cloud.google.com/apis/credentials
# - Create OAuth 2.0 Client ID (Web application)
# - Set Authorized redirect URIs to: http://localhost:3456/callback
# - Copy Client ID and Client Secret to .env
# - Enable YouTube Data API v3 in your Google Cloud project
#
# =============================================================================
