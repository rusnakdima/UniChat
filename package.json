{
  "name": "unichat",
  "version": "0.1.4",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:debug": "tauri build --debug",
    "tauri:build:fast": "tauri build --no-bundle",
    "tauri:build:android": "tauri android build",
    "build:frontend:check": "ng build --configuration production --output-hashing none",
    "build:optimized": "bun run build:prod && bun run tauri:build",
    "build:android:optimized": "bun run build:prod && bun run tauri:build:android",
    "build:smart": "./scripts/build-optimized.sh build desktop release",
    "build:smart:debug": "./scripts/build-optimized.sh build desktop debug",
    "build:smart:android": "./scripts/build-optimized.sh build android release",
    "build:clean": "./scripts/build-optimized.sh clean",
    "format": "prettier --write \"src/**/*.{ts,html,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,css}\"",
    "format:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml",
    "format:all": "bun run format && bun run format:rust",
    "lint:rust": "cargo clippy --manifest-path src-tauri/Cargo.toml -- -D warnings",
    "lint:rust:fix": "cargo clippy --manifest-path src-tauri/Cargo.toml --fix --allow-dirty",
    "lint:all": "bun run format:check && bun run lint:rust"
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "^20.2.14",
    "@angular/common": "^20.3.18",
    "@angular/compiler": "^20.3.18",
    "@angular/core": "^20.3.18",
    "@angular/forms": "^20.3.18",
    "@angular/material": "^20.2.14",
    "@angular/platform-browser": "^20.3.18",
    "@angular/router": "^20.3.18",
    "@tailwindcss/postcss": "4.1.18",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-deep-link": "^2.4.8",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "dompurify": "^3.3.3",
    "rxjs": "~7.8.2",
    "tmi.js": "^1.8.5",
    "tslib": "^2.8.1",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular/build": "^20.3.22",
    "@angular/cli": "^20.3.22",
    "@angular/compiler-cli": "^20.3.18",
    "@tauri-apps/cli": "^2.10.1",
    "@types/dompurify": "^3.2.0",
    "@types/tmi.js": "^1.8.6",
    "flowbite": "^4.0.1",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "4.1.18",
    "typescript": "~5.8.3"
  }
}